{
  "start_url": "https://www.uninettunouniversity.net/secure/it/LoginPage.aspx",
  "headless": false,
  "slow_mo_ms": 50,
  "user_data_dir": "./user_data",
  "check_interval_seconds": 15,
  "keepalive_interval_seconds": 120,
  "pause_grace_seconds": 40,
  "ended_threshold": 0.995,
  "end_tail_seconds": 10,
  "require_ended": true,
  "ended_confirm_cycles": 2,
  "next_button_selector": "#ctl01_mainContent_ctl00_hlLezioneSuccessiva",
  "next_button_wait_ms": 8000,
  "video_selector": "#videojsplayer",
  "logout_check_selector": "#btnLogin2, #btnLogin3",
  "log_video_state": true,
  "completed_log_path": "./completed_lectures.csv",
  "completed_log_json_path": "",
  "completed_log_txt_path": "./completed_lectures.txt",
  "completed_log_rotate_on_start": true,
  "completed_log_archive_dir": "./logs/completed_archive",
  "stuck_timeout_seconds": 180,
  "stuck_min_delta_seconds": 0.5,
  "stuck_cooldown_seconds": 60,
  "stuck_seek_seconds": 0,
  "stuck_reload_after_attempts": 2,
  "stuck_reload_on_error": true,
  "stuck_reload_cooldown_seconds": 120,
  "allow_playwright_fallback": false,
  "retry_with_fresh_profile": true,
  "fresh_profile_suffix": "_fresh",
  "screenshot_on_error": true,
  "screenshot_dir": "./screenshots",
  "log_dir": "./logs"
}
